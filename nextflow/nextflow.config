// ============================================================
// nextflow.config — Resource profiles for ONT WGS Pipeline
// ============================================================

manifest {
    name        = 'ont-wgs-pipeline'
    description = 'ONT WGS: QC → Alignment → SNP/SV Calling → Methylation'
    version     = '1.0.0'
    author      = 'divyam-vns'
    nextflowVersion = '>=23.10.0'
}

// Default parameters
params {
    outdir         = "results/nextflow"
    threads        = 8
    min_coverage   = 5
    basecaller_cfg = "dna_r10.4.1_e8.2_400bps_hac@v4.2.0"
    mod_cfg        = "dna_r10.4.1_e8.2_400bps_hac@v4.2.0_5mCG_5hmCG@v2"
}

// Process-level defaults
process {
    cpus   = { 4 * task.attempt }
    memory = { 2.GB * task.attempt }
    time   = { 2.h * task.attempt }

    errorStrategy = { task.exitStatus in [130, 137, 140] ? 'retry' : 'terminate' }
    maxRetries    = 2

    withName: 'MINIMAP2_ALIGN' {
        cpus   = 16
        memory = 24.GB
    }
    withName: 'CLAIR3_SNP' {
        cpus   = 2
        memory = 4.GB
    }
    withName: 'SNIFFLES2_SV' {
        cpus   = 2
        memory = 4.GB
    }
    withName: 'MODKIT_PILEUP' {
        cpus   = 2
        memory = 4.GB
    }
    withName: 'NANOPLOT' {
        cpus   = 4
        memory = 8.GB
    }
}

// ---- Profiles ----
profiles {

    // Standard: use conda envs, no containers
    standard {
        conda.enabled = true
        process.conda = "${projectDir}/../snakemake/envs/align.yaml"
    }

    // Docker profile
    docker {
        docker.enabled         = true
        docker.userEmulation   = true
        singularity.enabled    = false
        podman.enabled         = false

        process {
            withName: 'MINIMAP2_ALIGN|SAMTOOLS_SORT_INDEX' {
                container = 'quay.io/biocontainers/minimap2:2.26--he4a0461_2'
            }
            withName: 'SNIFFLES2_SV' {
                container = 'quay.io/biocontainers/sniffles:2.3.3--pyhdfd78af_0'
            }
            withName: 'MODKIT_PILEUP' {
                container = 'ontresearch/modkit:latest'
            }
            withName: 'NANOPLOT|MULTIQC' {
                container = 'quay.io/biocontainers/nanoplot:1.42.0--pyhdfd78af_0'
            }
        }
    }

    // Podman profile (macOS — no Docker daemon needed)
    podman {
        podman.enabled         = true
        docker.enabled         = false
        singularity.enabled    = false

        process {
            withName: 'MINIMAP2_ALIGN|SAMTOOLS_SORT_INDEX' {
                container = 'quay.io/biocontainers/minimap2:2.26--he4a0461_2'
            }
            withName: 'SNIFFLES2_SV' {
                container = 'quay.io/biocontainers/sniffles:2.3.3--pyhdfd78af_0'
            }
            withName: 'MODKIT_PILEUP' {
                container = 'docker.io/ontresearch/modkit:latest'
            }
            withName: 'NANOPLOT|MULTIQC' {
                container = 'quay.io/biocontainers/nanoplot:1.42.0--pyhdfd78af_0'
            }
        }
    }

    // Singularity (HPC)
    singularity {
        singularity.enabled    = true
        singularity.autoMounts = true
        docker.enabled         = false

        process {
            withName: 'MINIMAP2_ALIGN|SAMTOOLS_SORT_INDEX' {
                container = 'https://depot.galaxyproject.org/singularity/minimap2:2.26--he4a0461_2'
            }
            withName: 'CLAIR3_SNP' {
                container = 'docker://ontresearch/clair3:latest'
            }
            withName: 'SNIFFLES2_SV' {
                container = 'https://depot.galaxyproject.org/singularity/sniffles:2.3.3--pyhdfd78af_0'
            }
            withName: 'MODKIT_PILEUP' {
                container = 'docker://ontresearch/modkit:latest'
            }
        }
    }

    // HPC / SLURM
    hpc {
        process.executor       = 'slurm'
        process.queue          = 'standard'
        singularity.enabled    = true
        singularity.autoMounts = true
    }
}

// Execution reports
timeline { enabled = true;  file = "${params.outdir}/pipeline_timeline.html" }
report   { enabled = true;  file = "${params.outdir}/pipeline_report.html"   }
trace    { enabled = true;  file = "${params.outdir}/pipeline_trace.txt"     }
dag      { enabled = true;  file = "${params.outdir}/pipeline_dag.html"      }
